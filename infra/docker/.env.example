# =============================================================================
# AlphaStack — Environment Variables (.env.example)
# =============================================================================
# Copy to .env and fill in your values.  NEVER commit .env.
# =============================================================================

# ── General ────────────────────────────────────────────────────
ALPHASTACK_ENV=dev

# ── Database (PostgreSQL / TimescaleDB) ────────────────────────
DB_NAME=alphastack
DB_USER=alphastack
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_PORT_EXTERNAL=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT_EXTERNAL=6379

# ── API Server ─────────────────────────────────────────────────
API_PORT=8000
API_DEBUG=false

# ── MetaTrader 5 ───────────────────────────────────────────────
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
MT5_VNC_PASSWORD=alphastack
MT5_VNC_PORT=3000
MT5_API_PORT=8080

# ── Broker: OANDA ─────────────────────────────────────────────
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# ── Broker: CCXT (Crypto) ─────────────────────────────────────
CCXT_API_KEY=
CCXT_SECRET=
CCXT_EXCHANGE=binance

# ── LLM ───────────────────────────────────────────────────────
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=

# ── Market Data ────────────────────────────────────────────────
FEED_POLYGON_API_KEY=
FEED_ALPHA_VANTAGE_API_KEY=
FEED_FINNHUB_API_KEY=

# ── Monitoring ─────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_URL=http://localhost:3001
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
REDIS_EXPORTER_PORT=9121
PG_EXPORTER_PORT=9187
NODE_EXPORTER_PORT=9100
